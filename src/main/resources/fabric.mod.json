{
	"schemaVersion": 1,
	"id": "starlight-preserved",
	"version": "${version}",
	"name": "Starlight Preserved",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/starlight-preserved/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "studio.starrybyte.starlightperserved.StarlightPreserved",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "studio.starrybyte.starlightperserved.StarlightPreservedClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "studio.starrybyte.starlightperserved.StarlightPreservedDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"starlight-preserved.mixins.json",
		{
			"config": "starlight-preserved.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}